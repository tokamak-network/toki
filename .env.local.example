# Privy App ID (https://dashboard.privy.io)
NEXT_PUBLIC_PRIVY_APP_ID=

# Pimlico Bundler API Key (https://dashboard.pimlico.io)
NEXT_PUBLIC_PIMLICO_API_KEY=

# Ethereum RPC URL (Alchemy or Infura)
NEXT_PUBLIC_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# TON Paymaster contract address (after deployment)
NEXT_PUBLIC_TON_PAYMASTER_ADDRESS=
